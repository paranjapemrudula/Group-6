DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=YOUR_VM_PUBLIC_IP,YOUR_DOMAIN,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://YOUR_VM_PUBLIC_IP,http://YOUR_DOMAIN,https://YOUR_DOMAIN,http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://YOUR_VM_PUBLIC_IP,http://YOUR_DOMAIN,https://YOUR_DOMAIN,http://localhost:5173,http://127.0.0.1:5173

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=myfinance_db
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=your_actual_postgres_password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

